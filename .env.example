# ── Meesho Credentials ────────────────────────────────────────────────────────
MEESHO_EMAIL=your_supplier_email@example.com
MEESHO_PASSWORD=your_supplier_password
MEESHO_SUPPLIER_ID=your_supplier_id          # Optional; auto-detected if blank

# ── LLM Provider (pick one) ───────────────────────────────────────────────────
LLM_PROVIDER=anthropic                        # Options: anthropic | openai
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...                         # Only needed if LLM_PROVIDER=openai

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password         # Use Gmail App Password, NOT account password
REPORT_RECIPIENT_EMAIL=shubham@example.com    # Where the daily report goes
REPORT_CC_EMAILS=                             # Comma-separated list, optional

# ── Report Settings ───────────────────────────────────────────────────────────
REPORT_DOWNLOAD_DIR=./reports/downloads       # Local path to save PDF/HTML reports
REPORT_SCHEDULE_TIME=08:00                    # 24-hr format; daily report trigger time (IST)
REPORT_TIMEZONE=Asia/Kolkata

# ── Browser Settings ──────────────────────────────────────────────────────────
HEADLESS=true                                 # false = shows browser window (useful for debugging)
BROWSER_TIMEOUT=60000                         # milliseconds
SLOW_MO=0                                     # ms delay between actions; 500 useful for debugging

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                                # DEBUG | INFO | WARNING | ERROR
LOG_DIR=./logs
